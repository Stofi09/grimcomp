{
  "name": "grimcomp",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "node scripts/dev-ios.js 'iPad Pro 13-inch (M5)'",
    "start:metro": "node scripts/dev-ios.js 'iPad Pro 13-inch (M5)' --no-launch",
    "start:raw": "expo start",
    "ios": "node scripts/dev-ios.js 'iPad Pro 13-inch (M5)'",
    "ios:ipad": "node scripts/dev-ios.js 'iPad Pro 13-inch (M5)'",
    "ios:ipad:11": "node scripts/dev-ios.js 'iPad Pro 11-inch (M5)'",
    "ios:iphone": "node scripts/dev-ios.js 'iPhone 17 Pro'",
    "android": "expo start --android",
    "web": "expo start --web",
    "tsc": "tsc --noEmit",
    "icons": "node scripts/generate-icons.js",
    "build:ios": "eas build --platform ios --profile production",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "submit:ios": "eas submit --platform ios --profile production --latest"
  },
  "dependencies": {
    "@expo-google-fonts/im-fell-english": "^0.2.3",
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo-google-fonts/jetbrains-mono": "^0.2.3",
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~51.0.28",
    "expo-font": "~12.0.10",
    "expo-linear-gradient": "~13.0.2",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.5",
    "react-native-svg": "15.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.2.79",
    "babel-plugin-module-resolver": "^5.0.2",
    "sharp": "^0.34.5",
    "typescript": "~5.3.3"
  },
  "private": true
}
